{
  "name": "steady-api",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker backend for the Steady motivation app.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create steady",
    "db:migrate:local": "wrangler d1 migrations apply steady --local",
    "db:migrate:remote": "wrangler d1 migrations apply steady --remote",
    "db:seed:local": "wrangler d1 execute steady --local --file=./migrations/0002_seed.sql",
    "db:seed:remote": "wrangler d1 execute steady --remote --file=./migrations/0002_seed.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250401.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.50.0"
  },
  "dependencies": {
    "hono": "^4.4.0"
  }
}
